APP_NAME="CN Community Platform 2026"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://community.example.nl
APP_TIMEZONE=Europe/Amsterdam
APP_LOCALE=nl

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cncommunity
DB_USERNAME=cncommunity
DB_PASSWORD=

# Alleen tijdelijk nodig voor import uit de oude CN-database.
LEGACY_DB_HOST=
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=
LEGACY_DB_USERNAME=
LEGACY_DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.nl
MAIL_FROM_NAME="${APP_NAME}"

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
